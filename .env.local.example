# 复制为 .env.local 后生效。

# 数据来源开关:默认走 mock(lib/demo 演示数据)。
# 接后端时设为 false,并实现 lib/api 中的 fetch 分支。
NEXT_PUBLIC_USE_MOCK=true

# 后端 API 根地址(NEXT_PUBLIC_USE_MOCK=false 时使用)
NEXT_PUBLIC_API_BASE=https://api.zhishu.example/v1

# Dify 知识库 API 密钥（仅服务端使用）
DIFY_API_BASE_URL=https://api.dify.ai/v1
DIFY_DATASET_API_KEY=dataset-your-secret-key
DIFY_DATASET_ID=your-dataset-id
